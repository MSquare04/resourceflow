    {
      "name": "01 — Admin demo",
      "item": [
        {
          "name": "Login — Анна Смирнова (admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json; charset=utf-8"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{demoPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"HTTP 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test(\"success = true\", () => pm.expect(json.success).to.eql(true));",
                  "pm.test(\"access token exists\", () => pm.expect(json.data.access_token).to.be.a(\"string\").and.not.empty);",
                  "pm.test(\"role admin\", () => pm.expect(json.data.user.roles).to.include(\"admin\"));",
                  "pm.environment.set(\"adminToken\", json.data.access_token);"
                ]
              }
            }
          ]
        },
